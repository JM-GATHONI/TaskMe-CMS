# ── Supabase (Vite client) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=YOUR_PRODUCTION_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_PRODUCTION_SUPABASE_ANON_KEY

# ── Supabase (server-side only — Edge Functions & migrations) ───────────────
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_SERVER_ONLY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET_IF_CONFIGURED

# ── Email — Resend (used by send-email Edge Function) ───────────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=nonreply@mail.task-me.ke

# ── SMS — set SMS_PROVIDER to enable real delivery ──────────────────────────
# Supported: "africastalking" | "twilio"  (leave blank to queue/log only)
SMS_PROVIDER=

# Africa's Talking (recommended for Kenya)
AT_API_KEY=YOUR_AT_API_KEY
AT_USERNAME=sandbox
AT_SENDER_ID=TASKME

# Twilio (alternative)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+1234567890

# ── WhatsApp — Meta Cloud API ────────────────────────────────────────────────
# Get from: developers.facebook.com → WhatsApp → API Setup
WHATSAPP_API_KEY=YOUR_META_SYSTEM_USER_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID

# ── Website (public-facing site) ────────────────────────────────────────────
# Base URL of the website. Used to construct all share/referral links.
# Defaults to https://task-me.ke if not set.
VITE_WEBSITE_URL=https://task-me.ke

# ── Website API (optional) ──────────────────────────────────────────────────
# Set when task-me.ke exposes a REST API for leads/fundi-jobs.
# If not set, data arrives via receive-lead and fundi-job-submit webhooks.
VITE_WEBSITE_API_URL=
VITE_WEBSITE_API_KEY=
